/* qtb.keymap */
#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/pointing.h>
#include <input/processors.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>

/ {
    /* -----------------------------------------------------------
     * コンボ定義
     *  - Layer1中のMB4(3)+MB5(4)同時押し → BT_CLR_ALL
     * ----------------------------------------------------------- */
    combos {
        compatible = "zmk,combos";

        combo_bt_clr {
            timeout-ms = <50>;
            key-positions = <3 4>;        /* MB4 + MB5 */
            bindings = <&bt BT_CLR_ALL>;
            layers = <1 5 6 7>;           /* 全スクロールレイヤーで有効 */
        };
    };

    /* -----------------------------------------------------------
     * トラックボール入力プロセッサー
     * ----------------------------------------------------------- */
    zip_xy_scaler: zip_xy_scaler {
        compatible = "zmk,input-processor-scaler";
        #input-processor-cells = <2>;
        type = <INPUT_EV_REL>;
        codes = <INPUT_REL_X INPUT_REL_Y>;
    };

    zip_scroll_scaler: zip_scroll_scaler {
        compatible = "zmk,input-processor-scaler";
        #input-processor-cells = <2>;
        type = <INPUT_EV_REL>;
        codes = <INPUT_REL_X INPUT_REL_Y>;
    };

    zip_scroll_mapper: zip_scroll_mapper {
        compatible = "zmk,input-processor-code-mapper";
        #input-processor-cells = <0>;
        type = <INPUT_EV_REL>;
        map = <INPUT_REL_Y INPUT_REL_WHEEL>;
    };

    trackball_listener {
        compatible = "zmk,input-listener";
        device = <&trackball>;

        scroll_layer {
            layers = <1 5 6 7>;
            input-processors = <&zip_scroll_scaler (-1) 32>, <&zip_scroll_mapper>;
        };

        layer_1200 {
            layers = <2>;
            input-processors = <&zip_xy_scaler 3 2>;
        };

        layer_1600 {
            layers = <3>;
            input-processors = <&zip_xy_scaler 3 1>;
        };

        layer_400 {
            layers = <4>;
            input-processors = <&zip_xy_scaler 1 2>;
        };

        default_layer {
            layers = <0>;
            input-processors = <&zip_xy_scaler 1 1>;
        };
    };

    /* -----------------------------------------------------------
     * キーマップ
     *
     *  キー番号 (0始まり):
     *   0:LCLK  1:RCLK  2:MCLK  3:MB4   4:MB5
     *   5:左チルト  6:右チルト  7:スクロールレイヤー
     *
     *  Layer0 通常操作:
     *   LCLK / RCLK / MCLK / MB4 / MB5 / 左チルト / 右チルト / [ホールド→Layer1]
     *
     *  Layer1 スクロールモード（スクロールレイヤーボタンホールド中）:
     *   左チルト → CPI切替（順送り）
     *   MB4+MB5  → BT_CLR_ALL（combo）
     * ----------------------------------------------------------- */
    keymap {
        compatible = "zmk,keymap";

        /* Layer 0: Default 800 CPI */
        default_layer {
            display-name = "800";
            bindings = <
                &mkp LCLK       /* 0: LCLK      */
                &mkp RCLK       /* 1: RCLK      */
                &mkp MCLK       /* 2: MCLK      */
                &mkp MB4        /* 3: MB4       */
                &mkp MB5        /* 4: MB5       */
                &msc SCRL_LEFT  /* 5: 左チルト   */
                &msc SCRL_RIGHT /* 6: 右チルト   */
                &mo 1           /* 7: →Layer1   */
            >;
        };

        /* Layer 1: スクロール + CPI切替 + BT_CLR */
        scroll_layer {
            display-name = "Scroll";
            bindings = <
                &trans          /* 0: LCLK      */
                &trans          /* 1: RCLK      */
                &trans          /* 2: MCLK      */
                &trans          /* 3: MB4 (combo用) */
                &trans          /* 4: MB5 (combo用) */
                &to 2           /* 5: 左チルト → CPI切替(1200へ) */
                &trans          /* 6: 右チルト  */
                &trans          /* 7: ホールド継続 */
            >;
        };

        /* Layer 2: 1200 CPI */
        layer_1200_cpi {
            display-name = "1200";
            bindings = <
                &mkp LCLK &mkp RCLK &mkp MCLK &mkp MB4
                &mkp MB5  &msc SCRL_LEFT  &msc SCRL_RIGHT  &mo 5
            >;
        };

        /* Layer 3: 1600 CPI */
        layer_1600_cpi {
            display-name = "1600";
            bindings = <
                &mkp LCLK &mkp RCLK &mkp MCLK &mkp MB4
                &mkp MB5  &msc SCRL_LEFT  &msc SCRL_RIGHT  &mo 6
            >;
        };

        /* Layer 4: 400 CPI */
        layer_400_cpi {
            display-name = "400";
            bindings = <
                &mkp LCLK &mkp RCLK &mkp MCLK &mkp MB4
                &mkp MB5  &msc SCRL_LEFT  &msc SCRL_RIGHT  &mo 7
            >;
        };

        /* Layer 5: スクロール@1200 + CPI切替 */
        scroll_1200 {
            display-name = "Scrl1200";
            bindings = <
                &trans &trans &trans &trans
                &trans  &to 3  &trans  &trans
            >;
        };

        /* Layer 6: スクロール@1600 + CPI切替 */
        scroll_1600 {
            display-name = "Scrl1600";
            bindings = <
                &trans &trans &trans &trans
                &trans  &to 4  &trans  &trans
            >;
        };

        /* Layer 7: スクロール@400 + CPI切替 */
        scroll_400 {
            display-name = "Scrl400";
            bindings = <
                &trans &trans &trans &trans
                &trans  &to 0  &trans  &trans
            >;
        };
    };
};
